# Bhoonidhi credentials are read at runtime; never commit real values.
BHOONIDHI_USERNAME=
BHOONIDHI_PASSWORD=
BHOONIDHI_BASE_URL=https://bhoonidhi-api.nrsc.gov.in

# Backend and database.
DATABASE_URL=postgresql+psycopg://uncloud:uncloud@postgres:5432/uncloud
SECRET_KEY=change-me-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./data/storage

# Optional S3-compatible object storage.
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# Planetary Computer STAC (Sentinel-1, Sentinel-2, Copernicus DEM).
PLANETARY_COMPUTER_SUBSCRIPTION_KEY=

# Experiment tracking.
WANDB_API_KEY=
WANDB_PROJECT=uncloud-it

# Frontend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
